# ── Visual Studio IDE ──────────────────────────────────────────────
.vs/
*.slnx
*.sln
slnx.sqlite
ProjectSettings.json
*.vcxproj
*.vcxproj.filters
*.vcxproj.user

# ── VS Code workspace cache ────────────────────────────────────────
# Track the C/C++ configuration required for ESP32 firmware IntelliSense.
.vscode/*
!.vscode/c_cpp_properties.json

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.env
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ── Arduino / PlatformIO build output ─────────────────────────────
.pio/
.pioenvs/
.piolibdeps/
.arduino-build/

# ── Operating system noise ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Logs and temp files ────────────────────────────────────────────
*.log
*.tmp
*.temp

# ── Project-specific generated files ──────────────────────────────
# NDJSON telemetry written by relay.py — grows every session, never commit
server/performance_logs.json
